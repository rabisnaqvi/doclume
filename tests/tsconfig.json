{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": "..",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vitest/globals"],
    "paths": {
      "@doclume/core": ["packages/core/src/index.ts"],
      "react": ["packages/web/node_modules/@types/react/index.d.ts"],
      "react-dom/client": ["packages/web/node_modules/@types/react-dom/client.d.ts"],
      "react-dom/test-utils": ["packages/web/node_modules/@types/react-dom/test-utils/index.d.ts"]
    }
  },
  "include": ["../vitest.config.ts", "../packages/core/src/**/*.ts", "./**/*.ts"],
  "exclude": ["**/*.js"]
}
