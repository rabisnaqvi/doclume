{
  "name": "doclume",
  "displayName": "Doclume",
  "description": "Markdown preview with beautiful typography and themes. Serif and sans reading modes, dark and light, for VS Code.",
  "version": "0.2.0",
  "publisher": "rabisnaqvi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rabisnaqvi/doclume.git"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Formatters",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "markdown",
    "preview",
    "markdown preview",
    "themes",
    "reader",
    "markdown viewer",
    "dark theme",
    "light theme",
    "serif",
    "typography",
    "reading mode",
    "document viewer",
    "markdown reader",
    "beautiful markdown",
    "markdown themes"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:prompt",
    "onLanguage:instructions",
    "onLanguage:chatagent",
    "onLanguage:skill",
    "onCommand:doclume.selectTheme",
    "onCommand:doclume.cycleTheme"
  ],
  "icon": "images/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "doclume.openPreview",
        "title": "Open in Doclume",
        "category": "Doclume",
        "icon": "$(book)"
      },
      {
        "command": "doclume.selectTheme",
        "title": "Select Doclume Theme…",
        "category": "Doclume",
        "icon": "$(color-mode)"
      },
      {
        "command": "doclume.cycleTheme",
        "title": "Cycle Doclume Theme",
        "category": "Doclume",
        "icon": "$(arrow-swap)"
      }
    ],
    "keybindings": [
      {
        "command": "doclume.openPreview",
        "key": "ctrl+k ctrl+shift+l",
        "mac": "cmd+k cmd+shift+l",
        "when": "editorTextFocus && editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused"
      },
      {
        "command": "doclume.openPreview",
        "key": "ctrl+shift+alt+l",
        "mac": "cmd+shift+alt+l",
        "when": "editorTextFocus && editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "doclume.openPreview",
          "when": "editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused",
          "group": "navigation@0"
        }
      ],
      "modalEditor/editorTitle": [
        {
          "command": "doclume.openPreview",
          "when": "editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused",
          "group": "navigation@0"
        }
      ],
      "editor/context": [
        {
          "command": "doclume.openPreview",
          "when": "editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused",
          "group": "navigation@0"
        }
      ],
      "editor/title/context": [
        {
          "command": "doclume.openPreview",
          "when": "resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/",
          "group": "1_open"
        }
      ],
      "explorer/context": [
        {
          "command": "doclume.openPreview",
          "when": "resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/",
          "group": "navigation@0"
        }
      ],
      "commandPalette": [
        {
          "command": "doclume.openPreview",
          "when": "editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused"
        },
        {
          "command": "doclume.selectTheme"
        },
        {
          "command": "doclume.cycleTheme"
        }
      ]
    },
    "configurationDefaults": {
      "files.associations": {
        "*.chatagent": "markdown",
        "*.instructions": "markdown",
        "*.prompt": "markdown",
        "*.skill": "markdown"
      }
    },
    "configuration": {
      "title": "Doclume",
      "properties": {
        "doclume.theme": {
          "type": "string",
          "enum": [
            "auto",
            "library",
            "lamplight",
            "manual",
            "console",
            "contrast"
          ],
          "enumDescriptions": [
            "Match VS Code light/dark (Manual in light, Console in dark)",
            "Long reads · light (serif, warm cream)",
            "Long reads · dark (serif, amber-toned)",
            "Spec / docs · light (sans, clean)",
            "Spec / docs · dark (sans, IDE-style)",
            "High contrast (accessibility)"
          ],
          "default": "auto",
          "description": "Doclume theme for the markdown preview. \"auto\" follows the active workbench color theme (light → Manual, dark → Console)."
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm build:ext && pnpm build:webview",
    "build:ext": "node build.mjs",
    "build:webview": "vite build",
    "watch": "pnpm build:ext -- --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies && ovsx publish --no-dependencies"
  },
  "dependencies": {
    "@doclume/core": "workspace:*",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.93.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.26.0",
    "ovsx": "^0.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^6.4.2"
  }
}
