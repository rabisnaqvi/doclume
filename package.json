{
  "name": "doclume-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "gen-icons": "node scripts/gen-icons.mjs",
    "dev": "pnpm --filter @doclume/web dev",
    "build": "pnpm --filter @doclume/core build && pnpm --filter @doclume/web build && pnpm --filter doclume build",
    "build:core": "pnpm --filter @doclume/core build",
    "build:web": "pnpm --filter @doclume/web build",
    "deploy:worker": "pnpm dlx wrangler deploy --config wrangler.toml",
    "deploy:worker:preview": "pnpm dlx wrangler versions upload --config wrangler.toml",
    "build:ext": "pnpm --filter doclume build",
    "package:ext": "pnpm --filter doclume package",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "typescript": "^5.5.3"
  }
}
