{
  "name": "doclume",
  "displayName": "Doclume",
  "description": "A beautiful markdown preview — Library, Lamplight, Manual, Console, and more themes.",
  "version": "0.1.0",
  "publisher": "rabisnaqvi",
  "private": true,
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "doclume.openPreview",
        "title": "Open in Doclume",
        "icon": "$(book)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "doclume.openPreview",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "doclume.openPreview",
          "when": "resourceExtname == .md"
        }
      ]
    },
    "configuration": {
      "title": "Doclume",
      "properties": {
        "doclume.theme": {
          "type": "string",
          "enum": ["auto", "library", "lamplight", "manual", "console", "contrast"],
          "enumDescriptions": [
            "Match VS Code light/dark (Manual in light, Console in dark)",
            "Long reads · light (serif, warm cream)",
            "Long reads · dark (serif, amber-toned)",
            "Spec / docs · light (sans, clean)",
            "Spec / docs · dark (sans, IDE-style)",
            "High contrast (accessibility)"
          ],
          "default": "auto",
          "description": "Doclume theme for the markdown preview. \"auto\" follows the active workbench color theme (light → Manual, dark → Console)."
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm build:ext && pnpm build:webview",
    "build:ext": "node build.mjs",
    "build:webview": "vite build",
    "watch": "pnpm build:ext -- --watch",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@doclume/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
